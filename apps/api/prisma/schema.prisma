generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Embedded Types (stored inside User document) ───────────────────────────

type Profile {
  name           String?
  summary        String?
  headline       String?
  location       String?
  phone          String?
  email          String?
  website        String?
  linkedin       String?
  github         String?
  imageUrl       String?
  showQrCode     Boolean        @default(true)
  experiences    Experience[]
  education      Education[]
  skills         Skill[]
  projects       Project[]
  certifications Certification[]
  publications   Publication[]
  volunteerWork  VolunteerWork[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now())
}

type Experience {
  title       String?
  company     String?
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?
  bullets     String[]
  orderIndex  Int       @default(0)
}

type Education {
  institution String?
  degree      String?
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  gpa         String?
  honors      String?
  description String?
  orderIndex  Int       @default(0)
}

type Skill {
  name        String
  category    String?
  proficiency String?
  orderIndex  Int     @default(0)
}

type Project {
  name        String?
  description String?
  url         String?
  techStack   String[]
  bullets     String[]
  startDate   DateTime?
  endDate     DateTime?
  orderIndex  Int       @default(0)
}

type Certification {
  name       String?
  issuer     String?
  date       DateTime?
  expiryDate DateTime?
  url        String?
  orderIndex Int       @default(0)
}

type Publication {
  title      String?
  venue      String?
  date       DateTime?
  url        String?
  orderIndex Int      @default(0)
}

type VolunteerWork {
  role         String?
  organization String?
  startDate    DateTime?
  endDate      DateTime?
  bullets      String[]
  orderIndex   Int       @default(0)
}

// ─── User ───────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  email            String    @unique
  name             String
  avatarUrl        String?
  passwordHash     String?
  oauthProvider    String?
  oauthId          String?
  twoFactorEnabled Boolean   @default(false)
  emailVerified    Boolean   @default(false)
  plan             String    @default("free")
  vanitySlug       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Embedded profile document
  profile          Profile?

  // Relations to other collections
  resumes      Resume[]
  coverLetters CoverLetter[]
  jobs         Job[]
  applications Application[]
  portfolio    Portfolio?
}

// ─── Verification Code ──────────────────────────────────────────────────────────

model VerificationCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Job ────────────────────────────────────────────────────────────────────────

model Job {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  company         String
  location        String?
  url             String?
  source          String   @default("manual")
  rawDescription  String
  parsedKeywords  Json?
  companyTone     String?
  matchScore      Int?
  matchBreakdown  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resumes       Resume[]
  applications  Application[]
  coverLetters  CoverLetter[]
}

// ─── Resume ─────────────────────────────────────────────────────────────────────

model Resume {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @db.ObjectId
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId                String?  @db.ObjectId
  job                  Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  name                 String
  baseProfileSnapshot  Json?
  tailoredContent      Json?
  templateId           String   @default("modern-01")
  customStyles         Json?
  sectionOrder         String[]
  sectionVisibility    Json?
  matchScore           Int?
  atsScore             Int?
  atsReport            Json?
  showQrCode           Boolean  @default(true)
  showProfileImage     Boolean  @default(true)

  isTailored           Boolean  @default(false)
  baseResumeId         String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  applications Application[]
  coverLetters CoverLetter[]
}

// ─── Cover Letter ───────────────────────────────────────────────────────────────

model CoverLetter {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId   String?  @db.ObjectId
  resume     Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobId      String?  @db.ObjectId
  job        Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title      String
  content    String
  tone       String   @default("formal")
  templateId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Application ────────────────────────────────────────────────────────────────

model Application {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId          String?   @db.ObjectId
  job            Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  resumeId       String?   @db.ObjectId
  resume         Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  coverLetterId  String?
  status         String    @default("saved")
  appliedAt      DateTime?
  notes          String?
  contactName    String?
  contactEmail   String?
  salaryRange    String?
  nextDeadline   DateTime?
  reminderSent   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Portfolio ──────────────────────────────────────────────────────────────────

model Portfolio {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId       String   @default("modern")
  primaryColor     String   @default("#818cf8")
  accentColor      String   @default("#6366f1")
  showExperience   Boolean  @default(true)
  showProjects     Boolean  @default(true)
  showEducation    Boolean  @default(true)
  showSkills       Boolean  @default(true)
  showPublications Boolean  @default(false)
  showVolunteer    Boolean  @default(false)
  customHeadline   String?
  customBio        String?
  passwordHash     String?
  isPublic         Boolean  @default(true)
  totalViews       Int      @default(0)
  lastViewedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
