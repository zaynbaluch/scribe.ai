generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ───────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  avatarUrl     String?
  oauthProvider String   // google, linkedin, github
  oauthId       String   @unique
  plan          String   @default("free") // free, pro, lifetime
  vanitySlug    String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile      Profile?
  resumes      Resume[]
  coverLetters CoverLetter[]
  jobs         Job[]
  applications Application[]
  portfolio    Portfolio?
}

// ─── Profile ────────────────────────────────────────────────────────────────────

model Profile {
  id        String @id @default(uuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  summary   String? @db.Text
  headline  String?
  location  String?
  phone     String?
  website   String?
  linkedin  String?
  github    String?
  imageUrl  String?   @db.Text

  experiences    Experience[]
  education      Education[]
  skills         Skill[]
  projects       Project[]
  certifications Certification[]
  publications   Publication[]
  volunteerWork  VolunteerWork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Experience ─────────────────────────────────────────────────────────────────

model Experience {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  company     String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text
  bullets     String[]
  orderIndex  Int       @default(0)
}

// ─── Education ──────────────────────────────────────────────────────────────────

model Education {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  gpa         String?
  honors      String?
  description String?   @db.Text
  orderIndex  Int       @default(0)
}

// ─── Skill ──────────────────────────────────────────────────────────────────────

model Skill {
  id          String  @id @default(uuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  category    String? // language, framework, tool, database, cloud, soft-skill
  proficiency String? // beginner, intermediate, advanced, expert
  orderIndex  Int     @default(0)
}

// ─── Project ────────────────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  url         String?
  techStack   String[]
  bullets     String[]
  startDate   DateTime?
  endDate     DateTime?
  orderIndex  Int       @default(0)
}

// ─── Certification ──────────────────────────────────────────────────────────────

model Certification {
  id         String    @id @default(uuid())
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  issuer     String
  date       DateTime?
  expiryDate DateTime?
  url        String?
  orderIndex Int       @default(0)
}

// ─── Publication ────────────────────────────────────────────────────────────────

model Publication {
  id        String    @id @default(uuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  venue     String?
  date      DateTime?
  url       String?
  orderIndex Int      @default(0)
}

// ─── Volunteer Work ─────────────────────────────────────────────────────────────

model VolunteerWork {
  id           String    @id @default(uuid())
  profileId    String
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role         String
  organization String
  startDate    DateTime?
  endDate      DateTime?
  bullets      String[]
  orderIndex   Int       @default(0)
}

// ─── Job ────────────────────────────────────────────────────────────────────────

model Job {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  company         String
  location        String?
  url             String?
  source          String   @default("manual") // manual, linkedin, indeed, glassdoor, extension, image
  rawDescription  String   @db.Text
  parsedKeywords  Json?    // { required: [], preferred: [], tools: [], softSkills: [] }
  companyTone     String?  // startup, corporate, creative, academic
  matchScore      Int?
  matchBreakdown  Json?    // { strong: [], partial: [], gaps: [] }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resumes       Resume[]
  applications  Application[]
  coverLetters  CoverLetter[]
}

// ─── Resume ─────────────────────────────────────────────────────────────────────

model Resume {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId                String?
  job                  Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  name                 String
  baseProfileSnapshot  Json?    // frozen copy of profile sections at creation
  tailoredContent      Json?    // AI-modified content
  templateId           String   @default("modern-01")
  customStyles         Json?    // font, spacing, color overrides
  sectionOrder         String[] // ordered list of visible sections
  sectionVisibility    Json?    // { skills: true, projects: false, ... }
  matchScore           Int?
  atsScore             Int?
  atsReport            Json?
  
  isTailored           Boolean  @default(false)
  baseResumeId         String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  applications Application[]
  coverLetters CoverLetter[]
}

// ─── Cover Letter ───────────────────────────────────────────────────────────────

model CoverLetter {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId   String?
  resume     Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobId      String?
  job        Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title      String
  content    String   @db.Text
  tone       String   @default("formal") // formal, conversational, storytelling
  templateId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Application ────────────────────────────────────────────────────────────────

model Application {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId          String?
  job            Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  resumeId       String?
  resume         Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  coverLetterId  String?
  status         String    @default("saved") // saved, applied, screening, interview, offer, rejected, withdrawn
  appliedAt      DateTime?
  notes          String?   @db.Text
  contactName    String?
  contactEmail   String?
  salaryRange    String?
  nextDeadline   DateTime?
  reminderSent   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Portfolio ──────────────────────────────────────────────────────────────────

model Portfolio {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId       String   @default("developer")
  primaryColor     String   @default("#818cf8")
  accentColor      String   @default("#6366f1")
  showExperience   Boolean  @default(true)
  showProjects     Boolean  @default(true)
  showEducation    Boolean  @default(true)
  showSkills       Boolean  @default(true)
  showPublications Boolean  @default(false)
  showVolunteer    Boolean  @default(false)
  customHeadline   String?
  customBio        String?  @db.Text
  passwordHash     String?  // bcrypt hash if password-protected
  isPublic         Boolean  @default(true)
  totalViews       Int      @default(0)
  lastViewedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
