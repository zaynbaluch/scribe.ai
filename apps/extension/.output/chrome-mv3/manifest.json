{"manifest_version":3,"name":"Scribe.ai","description":"Save jobs and auto-tailor resumes directly from job boards.","version":"1.0.0","icons":{"16":"logo.png","32":"logo.png","48":"logo.png","128":"logo.png"},"permissions":["storage","activeTab","tabs","scripting"],"action":{"default_icon":"logo.png","default_title":"Scribe.ai Popup","default_popup":"popup.html"},"host_permissions":["*://*.linkedin.com/*","*://*.indeed.com/*"],"background":{"service_worker":"background.js"},"content_scripts":[{"matches":["*://*.indeed.com/jobs*","*://*.indeed.com/m/viewjob*","*://*.indeed.com/viewjob*"],"css":["content-scripts/indeed.css"],"js":["content-scripts/indeed.js"]},{"matches":["*://*.linkedin.com/jobs/*","*://*.linkedin.com/jobs/collections/*","*://*.linkedin.com/jobs/view/*"],"css":["content-scripts/linkedin.css"],"js":["content-scripts/linkedin.js"]}]}